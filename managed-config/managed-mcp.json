{
  "$schema": "https://forge-platform.dev/schemas/managed-mcp.json",
  "_comment": "Enterprise managed MCP server configuration. Deployed alongside managed-settings.json. Defines which MCP servers are available, how they authenticate, and their resource limits.",
  "version": "1.0.0",
  "mcpServers": {
    "forge-knowledge": {
      "command": "java",
      "args": [
        "-Xmx512m",
        "-jar",
        "${FORGE_HOME}/mcp-servers/forge-knowledge-mcp.jar"
      ],
      "env": {
        "FORGE_KNOWLEDGE_DIR": "${FORGE_KNOWLEDGE_DIR:-/opt/forge/knowledge-base}",
        "FORGE_WIKI_ENDPOINT": "${CONFLUENCE_API_URL}",
        "FORGE_WIKI_TOKEN": "${CONFLUENCE_API_TOKEN}",
        "SERVER_PORT": "8081",
        "OAUTH2_ISSUER": "${OAUTH2_ISSUER_URL}",
        "LOG_LEVEL": "INFO"
      },
      "transport": "http",
      "healthCheck": {
        "url": "http://localhost:8081/health",
        "intervalSeconds": 30,
        "timeoutSeconds": 5
      },
      "resourceLimits": {
        "maxConcurrentRequests": 20,
        "requestTimeoutSeconds": 30,
        "maxResponseSizeBytes": 1048576
      }
    },
    "forge-database": {
      "command": "java",
      "args": [
        "-Xmx512m",
        "-jar",
        "${FORGE_HOME}/mcp-servers/forge-database-mcp.jar"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "DATABASE_READ_ONLY": "true",
        "MAX_POOL_SIZE": "5",
        "QUERY_TIMEOUT_SECONDS": "10",
        "MAX_ROWS": "1000",
        "SERVER_PORT": "8082",
        "OAUTH2_ISSUER": "${OAUTH2_ISSUER_URL}",
        "LOG_LEVEL": "INFO"
      },
      "transport": "http",
      "healthCheck": {
        "url": "http://localhost:8082/health",
        "intervalSeconds": 30,
        "timeoutSeconds": 5
      },
      "resourceLimits": {
        "maxConcurrentRequests": 10,
        "requestTimeoutSeconds": 15,
        "maxResponseSizeBytes": 5242880
      },
      "security": {
        "allowedOperations": ["SELECT"],
        "blockedOperations": ["INSERT", "UPDATE", "DELETE", "DROP", "ALTER", "TRUNCATE", "CREATE"],
        "allowedSchemas": ["public", "analytics"],
        "blockedSchemas": ["pg_catalog", "information_schema"]
      }
    },
    "forge-service-graph": {
      "command": "java",
      "args": [
        "-Xmx256m",
        "-jar",
        "${FORGE_HOME}/mcp-servers/forge-service-graph-mcp.jar"
      ],
      "env": {
        "SERVICE_REGISTRY_URL": "${SERVICE_REGISTRY_URL:-http://localhost:8500}",
        "SERVER_PORT": "8083",
        "OAUTH2_ISSUER": "${OAUTH2_ISSUER_URL}",
        "LOG_LEVEL": "INFO"
      },
      "transport": "http",
      "healthCheck": {
        "url": "http://localhost:8083/health",
        "intervalSeconds": 60,
        "timeoutSeconds": 5
      },
      "resourceLimits": {
        "maxConcurrentRequests": 15,
        "requestTimeoutSeconds": 20,
        "maxResponseSizeBytes": 2097152
      }
    },
    "forge-artifact": {
      "command": "java",
      "args": [
        "-Xmx256m",
        "-jar",
        "${FORGE_HOME}/mcp-servers/forge-artifact-mcp.jar"
      ],
      "env": {
        "ARTIFACT_STORE_PATH": "${FORGE_HOME}/artifacts",
        "SERVER_PORT": "8084",
        "OAUTH2_ISSUER": "${OAUTH2_ISSUER_URL}",
        "LOG_LEVEL": "INFO"
      },
      "transport": "http",
      "healthCheck": {
        "url": "http://localhost:8084/health",
        "intervalSeconds": 60,
        "timeoutSeconds": 5
      },
      "resourceLimits": {
        "maxConcurrentRequests": 10,
        "requestTimeoutSeconds": 30,
        "maxResponseSizeBytes": 10485760
      }
    },
    "forge-observability": {
      "command": "java",
      "args": [
        "-Xmx256m",
        "-jar",
        "${FORGE_HOME}/mcp-servers/forge-observability-mcp.jar"
      ],
      "env": {
        "PROMETHEUS_URL": "${PROMETHEUS_URL:-http://localhost:9090}",
        "GRAFANA_URL": "${GRAFANA_URL:-http://localhost:3000}",
        "LOKI_URL": "${LOKI_URL:-http://localhost:3100}",
        "SERVER_PORT": "8085",
        "OAUTH2_ISSUER": "${OAUTH2_ISSUER_URL}",
        "LOG_LEVEL": "INFO"
      },
      "transport": "http",
      "healthCheck": {
        "url": "http://localhost:8085/health",
        "intervalSeconds": 30,
        "timeoutSeconds": 5
      },
      "resourceLimits": {
        "maxConcurrentRequests": 20,
        "requestTimeoutSeconds": 30,
        "maxResponseSizeBytes": 5242880
      }
    }
  }
}
