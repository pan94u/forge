# =============================================================================
# Forge Trial 环境变量配置
# 复制此文件为 .env 并填入实际值：cp .env.trial.example .env
# .env 已加入 .gitignore，不会被提交
# =============================================================================

# --- 模型提供商（至少配置一个）---

# Option A: MiniMax
MODEL_PROVIDER=minimax
MINIMAX_API_KEY=<your-minimax-key>
MINIMAX_API_URL=https://api.minimaxi.com/anthropic

# Option B: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# Option C: OpenAI 兼容接口（Ollama / vLLM / 公司内网等）
# LOCAL_MODEL_URL=http://localhost:11434
# LOCAL_MODEL_NAME=llama3.1:8b
# LOCAL_MODEL_API_KEY=your-key

# Option D: Google Gemini
# GEMINI_API_KEY=AIza...

# Option E: 阿里云 DashScope
# DASHSCOPE_API_KEY=sk-...

# Option F: AWS Bedrock
# AWS_REGION=us-east-1
# AWS_PROFILE=default

# --- 加密密钥 ---
# API Key 加密密钥，生成方式: openssl rand -base64 32
# FORGE_ENCRYPTION_KEY=your-base64-key

# --- SSO ---
# 本地开发使用 sso.forge.local（需先启动 infrastructure/sso 并配置 /etc/hosts）
# 默认值已在 docker-compose.trial.yml 中设置，通常无需修改
# SSO_URL=http://sso.forge.local:8180/auth

# --- Enterprise Console ---
# NextAuth 会话加密密钥（Trial 有默认值，可不设；生产必须设置）
# NEXTAUTH_SECRET=forge-enterprise-nextauth-secret-32c
