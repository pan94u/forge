# Forge Docker 环境变量配置
# 复制此文件为 .env 并填入实际值：cp .env.trial.example .env
# .env 已加入 .gitignore，不会被提交

# ============================================================
# Model Provider（至少配置一个）
# ============================================================

# Option A: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# Option B: OpenAI 兼容接口（Ollama / vLLM / 公司内网等）
# LOCAL_MODEL_URL=http://localhost:11434
# LOCAL_MODEL_NAME=llama3.1:8b
# LOCAL_MODEL_API_KEY=your-key

# Option C: Google Gemini
# GEMINI_API_KEY=AIza...

# Option D: 阿里云 DashScope
# DASHSCOPE_API_KEY=sk-...

# Option E: AWS Bedrock
# AWS_REGION=us-east-1
# AWS_PROFILE=default

# ============================================================
# 安全配置
# ============================================================
# API Key 加密密钥，生成方式: openssl rand -base64 32
# FORGE_ENCRYPTION_KEY=your-base64-key

# ============================================================
# DataSource（默认 H2 内存库，生产环境替换为 PostgreSQL）
# ============================================================
# DB_URL=jdbc:postgresql://host:port/dbname
# DB_USERNAME=postgres
# DB_PASSWORD=your-password
# DB_DRIVER=org.postgresql.Driver
