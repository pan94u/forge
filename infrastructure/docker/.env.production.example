# =============================================================================
# Forge 生产环境变量模板
# 使用方式: cp .env.production.example .env.production && vim .env.production
# =============================================================================

# --- SSO（独立部署，必须修改）---
# SSO 服务器的公开 URL（所有应用共用同一个值）
SSO_URL=https://sso.forge.delivery/auth

# --- 域名配置（必须修改）---
FORGE_DOMAIN=forge.delivery
SSL_CERT_PATH=/opt/forge-ssl/forge.delivery_nginx

# --- 模型提供商（至少配置一个）---
MODEL_PROVIDER=minimax
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_API_URL=https://api.anthropic.com
MINIMAX_API_KEY=<your-minimax-key>
MINIMAX_API_URL=https://api.minimaxi.com/anthropic
# GEMINI_API_KEY=
# DASHSCOPE_API_KEY=

# --- 数据库（Forge 应用数据库，与 SSO 数据库完全隔离）---
# 生成强密码: openssl rand -base64 16
DB_PASSWORD=<strong-db-password>

# --- 加密密钥 ---
# 生成: openssl rand -base64 32
FORGE_ENCRYPTION_KEY=<openssl-rand-base64-32>

# --- 访问地址（浏览器可见）---
FORGE_FRONTEND_URL=https://forge.delivery
FORGE_CORS_ALLOWED_ORIGINS=https://forge.delivery

# --- Enterprise Console ---
# Keycloak client secret（与 SSO realm-export.json 中一致）
KEYCLOAK_ENTERPRISE_SECRET=enterprise-secret
# NextAuth 访问地址
NEXTAUTH_URL=https://forge.delivery
# NextAuth 会话加密密钥，生成: openssl rand -base64 32
NEXTAUTH_SECRET=<openssl-rand-base64-32>
