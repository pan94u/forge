# ============================================================
# Forge Platform — 生产环境变量
# 复制为 .env.production 并填入实际值
# ============================================================

# --- 外部访问地址 ---
FORGE_EXTERNAL_URL=https://your-domain.com

# --- 数据库密码（PG 跑在同机 Docker 里） ---
DB_PASSWORD=替换为强密码

# --- AI Provider（至少配一个） ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# DASHSCOPE_API_KEY=sk-xxxx
# GEMINI_API_KEY=AIza...
# LOCAL_MODEL_URL=http://host.docker.internal:11434
# LOCAL_MODEL_NAME=qwen2.5:14b

# --- 安全（生成: openssl rand -base64 32） ---
FORGE_ENCRYPTION_KEY=
FORGE_SECURITY_ENABLED=false
