# =============================================================================
# Forge 生产环境变量模板 — 4G 单机部署
# 使用方式: cp .env.production.example .env.production && vim .env.production
# =============================================================================

# --- 域名配置（必须修改）---
FORGE_DOMAIN=your-domain.com
SSL_CERT_PATH=/path/to/your-ssl-cert

# --- 模型提供商（至少配置一个）---
MODEL_PROVIDER=minimax
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_API_URL=https://api.anthropic.com
MINIMAX_API_KEY=<your-minimax-key>
MINIMAX_API_URL=https://api.minimaxi.com/anthropic
# GEMINI_API_KEY=
# DASHSCOPE_API_KEY=

# --- 数据库 ---
# 生成强密码: openssl rand -base64 16
DB_PASSWORD=<strong-db-password>

# --- 加密密钥 ---
# 生成: openssl rand -base64 32
FORGE_ENCRYPTION_KEY=<openssl-rand-base64-32>

# --- 访问地址（浏览器可见）---
# Web IDE 访问地址，用于 CORS 和前端跳转
FORGE_FRONTEND_URL=https://<your-domain>
FORGE_CORS_ALLOWED_ORIGINS=https://<your-domain>

# --- Keycloak SSO ---
# Keycloak 浏览器可见地址（用于 OAuth2 redirect + JWT iss 验证）
# 单域名模式：Keycloak 挂在 /auth/ 路径下
KEYCLOAK_PUBLIC_URL=https://<your-domain>/auth
# Keycloak 管理员密码（首次启动后请在 Admin 控制台修改）
KEYCLOAK_ADMIN_PASSWORD=<strong-admin-password>
# Enterprise Console 使用的 Keycloak client secret（与 realm-export.json 中一致）
KEYCLOAK_ENTERPRISE_SECRET=enterprise-secret

# --- Enterprise Console ---
# EC 访问地址（用于 NextAuth callback URL）
CONSOLE_PUBLIC_URL=https://<your-domain>/console
# NextAuth 会话加密密钥
# 生成: openssl rand -base64 32
NEXTAUTH_SECRET=<openssl-rand-base64-32>
