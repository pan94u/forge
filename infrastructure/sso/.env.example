# =============================================================================
# SSO 环境变量模板
# 复制为 .env（开发）或 .env.production（生产）
# =============================================================================

# --- SSO 公开地址 ---
# 此 URL 是所有应用接入 SSO 的唯一凭据。
# 开发: http://sso.forge.local:8180/auth（需配置 /etc/hosts: 127.0.0.1 sso.forge.local）
# 生产: https://sso.forge.delivery/auth（需配置 DNS + SSL 反向代理）
SSO_URL=http://sso.forge.local:8180/auth

# --- Keycloak ---
KC_COMMAND=start-dev          # 生产: start
KC_PORT=8180                  # 宿主机映射端口
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin       # 生产: <strong-password>，生成: openssl rand -base64 16
KC_PROXY=                     # 生产: edge（表示在反向代理后面）

# --- PostgreSQL ---
KC_DB_PASSWORD=keycloak       # 生产: <strong-password>，生成: openssl rand -base64 16

# --- Nginx + SSL（仅生产）---
# 启用 nginx: COMPOSE_PROFILES=production 或 docker compose --profile production up -d
COMPOSE_PROFILES=             # 生产: production
SSL_CERT_PATH=./ssl           # 生产: SSL 证书目录，需包含 sso.forge.delivery_bundle.crt 和 .key
