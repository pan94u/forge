# =============================================================================
# SSO 海尔部署配置 — 放到 infrastructure/sso/.env
# =============================================================================
# Keycloak 保持默认端口 8180，由 haier nginx:9100 代理
# 不需要改 KC_HTTP_PORT 和 KC_PORT

# --- Keycloak hostname（浏览器看到的 URL，决定 token issuer）---
# 外层 nginx 做 TLS 终止时必须用 https://
SSO_URL=https://forge-sso.haier.net/auth

# --- Proxy mode（外层 nginx 终止 TLS 时设为 edge）---
KC_PROXY=edge

# --- Realm 文件（haier 专用，URL 不含端口）---
KC_REALM_FILE=../haier/realm-export-haier.json

# --- Admin ---
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin

# --- Database ---
KC_DB_PASSWORD=keycloak
PG_DATA_PATH=/data/forge/sso-postgres
