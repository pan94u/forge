# =============================================================================
# SSO 海尔部署配置 — 放到 infrastructure/sso/.env
# =============================================================================

# --- 域名与端口 ---
SSO_URL=http://forge-sso.haier.net:9100/auth
SSO_HOSTNAME=forge-sso.haier.net
KC_HTTP_PORT=9100
KC_PORT=9100

# --- Realm 文件（使用 haier 专用 realm）---
KC_REALM_FILE=../haier/realm-export-haier.json

# --- Admin ---
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin

# --- Database ---
KC_DB_PASSWORD=keycloak
PG_DATA_PATH=/data/forge/sso-postgres
