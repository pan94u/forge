# =============================================================================
# Forge 海尔内部部署 — 环境变量
# 复制为 .env 并填入实际值：cp .env.example .env
# =============================================================================

# --- 域名（外层 nginx 80 → 主机端口）---
APP_URL=http://forge.haier.net
SSO_URL=http://forge-sso.haier.net:9100/auth

# --- 模型提供商（至少配置一个）---

# Option A: MiniMax（默认）
MODEL_PROVIDER=minimax
MINIMAX_API_KEY=<your-minimax-key>
MINIMAX_API_URL=https://api.minimaxi.com/anthropic

# Option B: Anthropic Claude
# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# Option C: Google Gemini
# MODEL_PROVIDER=gemini
# GEMINI_API_KEY=AIza...

# Option D: 阿里云 DashScope
# MODEL_PROVIDER=dashscope
# DASHSCOPE_API_KEY=sk-...

# Option E: OpenAI 兼容接口
# MODEL_PROVIDER=local
# LOCAL_MODEL_URL=http://host.docker.internal:11434
# LOCAL_MODEL_NAME=llama3.1:8b

# --- 数据目录 ---
DATA_ROOT=/data/forge

# --- 数据库密码 ---
DB_PASSWORD=forge123

# --- Enterprise Console ---
KC_ENTERPRISE_SECRET=enterprise-secret
NEXTAUTH_SECRET=forge-enterprise-nextauth-secret-32c

# --- 加密密钥（生成: openssl rand -base64 32）---
# FORGE_ENCRYPTION_KEY=your-base64-key
